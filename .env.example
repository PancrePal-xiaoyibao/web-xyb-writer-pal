# ============================================
# 数据库连接 (Prisma 使用 PostgreSQL)
# ============================================
# 方案一：使用 Supabase 托管 PostgreSQL（推荐，无需自建数据库）
#   在 Supabase 控制台 → Project Settings → Database → Connection string 获取
#   DATABASE_URL 用 Transaction pooler（端口 6543），追加 ?pgbouncer=true
#   DIRECT_URL 用 Direct connection（端口 5432），供 Prisma migrate 使用
# 将 [PASSWORD] 替换为你的数据库密码，[PROJECT_REF] 替换为项目引用，[REGION] 替换为区域
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# 方案二：使用自建/Docker PostgreSQL（docker-compose 默认方案）
# DATABASE_URL="postgresql://xyb_user:your_password@localhost:5432/xyb_article"
# DIRECT_URL="postgresql://xyb_user:your_password@localhost:5432/xyb_article"

# JWT 密钥（至少 32 字符的随机字符串，用于本应用自建认证）可用 openssl rand -hex 32 生成
JWT_SECRET="replace-with-output-of-openssl-rand-hex-32"

# MCP 文章下载服务端点（抓取微信文章原文，功能必需）
MCP_URL="https://changfengbox.top/api/mcp"

# ============================================
# LLM 配置（文章智能改写）
# ============================================
# provider 可选: stepfun | siliconflow | dashscope | deepseek | openai
LLM_PROVIDER="stepfun"
# 模型名（默认 step-3.5-flash，对应阶跃星辰 Step-3.5-Flash）
LLM_MODEL="step-3.5-flash"
# 按所选 provider 填对应一项 API Key 即可；支持逗号分隔多 key 自动轮换
STEPFUN_API_KEY=""
SILICONFLOW_API_KEY=""
DASHSCOPE_API_KEY=""
DEEPSEEK_API_KEY=""
# openai 兼容自定义端点（LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
# 可选通用覆盖项，优先级最高（设置后忽略上面各 provider 的 key/baseurl）
# LLM_API_KEY=""
# LLM_BASE_URL=""

# 任务配置
MAX_JOBS_PER_USER="1000"
JOB_RETENTION_DAYS="30"

# 文件存储路径（相对于项目根目录）
OUTPUT_DIR="./output"

# 日志：LOG_LEVEL 可选 debug|info|warn|error；设置 LOG_DIR 后会额外写入按天滚动的日志文件
LOG_LEVEL="info"
LOG_DIR="./logs"

# 应用运行端口
PORT="3000"
